{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astrolyn.ai/schemas/marriage_rule.schema.json",
  "title": "MarriageRule",
  "type": "object",
  "additionalProperties": false,
  "required": ["rule_id", "name", "domain", "event_family", "rule_type", "status", "priority", "conditions", "outputs"],
  "properties": {
    "rule_id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "domain": {"type": "string", "enum": ["relationship"]},
    "event_family": {"type": "string", "enum": ["marriage", "commitment", "union", "cohabitation", "separation", "reconciliation"]},
    "rule_type": {"type": "string", "enum": ["dasha", "transit", "fast_trigger", "classical_pattern", "compound"]},
    "status": {"type": "string", "enum": ["active", "experimental", "calibration", "deprecated"]},
    "priority": {"type": "integer", "minimum": 1, "maximum": 100},
    "polarity": {"type": "string", "enum": ["supportive", "neutral", "challenging", "mixed"]},
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_of"],
      "properties": {
        "all_of": {"type": "array", "items": {"$ref": "#/$defs/Condition"}},
        "any_of": {"type": "array", "items": {"$ref": "#/$defs/Condition"}},
        "none_of": {"type": "array", "items": {"$ref": "#/$defs/Condition"}}
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "broad_window_days": {"type": "integer", "minimum": 0},
        "exact_window_days": {"type": "integer", "minimum": 0},
        "confidence_decay_days": {"type": "integer", "minimum": 0}
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dasha_weight": {"type": "number"},
        "transit_weight": {"type": "number"},
        "fast_trigger_weight": {"type": "number"},
        "classical_weight": {"type": "number"}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbolic_label", "likelihood_band", "timing_band"],
      "properties": {
        "symbolic_label": {"type": "string"},
        "likelihood_band": {"type": "string", "enum": ["very_low", "low", "moderate", "high", "very_high"]},
        "timing_band": {"type": "string", "enum": ["broad", "narrow", "exact"]},
        "recommended_action": {"type": "string"}
      }
    },
    "metadata": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operator", "value"],
      "properties": {
        "kind": {"type": "string", "enum": ["dasha_lord", "antardasha_lord", "house_lord", "planet_in_house", "planet_aspect", "transit_house", "transit_aspect", "navamsa_house", "navamsa_lagna", "darakaraka", "mathematical_point", "nakshatra", "age_pattern", "sensitive_point"]},
        "operator": {"type": "string", "enum": ["equals", "in", "not_in", "overlaps", "within_orb", "aspecting", "conjunct", "trine", "square", "opposite"]},
        "value": {},
        "orb_degrees": {"type": "number", "minimum": 0},
        "required_strength": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
