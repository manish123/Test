{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astrolyn.ai/schemas/marriage_rule.schema.json",
  "title": "MarriageRule",
  "description": "Schema for marriage timing and quality rules. Supports the 5-layer semantic architecture: Dasha > Transit > Fast Trigger > Classical Pattern > Outcome/Quality.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "name",
    "domain",
    "event_family",
    "rule_type",
    "status",
    "priority",
    "conditions",
    "outputs"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique rule identifier, e.g. jyothishi_dasha_primary_marriage_triggers"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source_text": {
      "type": "object",
      "additionalProperties": false,
      "description": "Provenance tracking - which classical text this rule derives from",
      "properties": {
        "work_name": {
          "type": "string",
          "description": "Name of the source text"
        },
        "chapter": {
          "type": ["string", "null"]
        },
        "verse": {
          "type": ["string", "null"]
        },
        "page": {
          "type": ["string", "null"]
        },
        "quote": {
          "type": ["string", "null"],
          "description": "Direct quote from the source"
        },
        "translation": {
          "type": ["string", "null"],
          "description": "English translation if needed"
        }
      }
    },
    "domain": {
      "type": "string",
      "enum": ["relationship"],
      "description": "Marriage rules belong to the relationship domain"
    },
    "event_family": {
      "type": "string",
      "enum": ["marriage", "commitment", "union", "cohabitation", "separation", "reconciliation"]
    },
    "event_subtype": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "stable", "love", "arranged", "mixed", "delayed", "early",
          "second_marriage", "painful", "conflict_prone", "unstable",
          "intercaste", "foreign", "denial"
        ]
      },
      "description": "Qualitative subtypes this rule applies to"
    },
    "rule_type": {
      "type": "string",
      "enum": [
        "dasha",
        "transit",
        "fast_trigger",
        "classical_pattern",
        "combination",
        "house_activation",
        "aspect",
        "compound"
      ],
      "description": "Semantic layer this rule belongs to"
    },
    "status": {
      "type": "string",
      "enum": ["active", "experimental", "calibration", "deprecated"]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Higher value means stronger precedence within its layer"
    },
    "polarity": {
      "type": "string",
      "enum": ["supportive", "neutral", "challenging", "mixed"]
    },
    "timing_band": {
      "type": "string",
      "enum": ["broad", "medium", "narrow", "exact", "none"],
      "description": "How precise this rules timing is. none = structural/quality rule with no timing implication"
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "all_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          },
          "description": "ALL conditions must be true (AND logic)"
        },
        "any_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          },
          "description": "At least ONE condition must be true (OR logic)"
        },
        "none_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          },
          "description": "NONE of these conditions must be true (NOT logic)"
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "description": "What data axes the rule engine must extract to evaluate this rule",
      "properties": {
        "dasha": {
          "type": "array",
          "items": { "type": "string" }
        },
        "transit": {
          "type": "array",
          "items": { "type": "string" }
        },
        "houses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "planets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "nakshatra": {
          "type": "array",
          "items": { "type": "string" }
        },
        "d9": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sensitive_points": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Semantic interpretation metadata for decision layer",
      "properties": {
        "meaning": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": ["love", "arranged", "mixed", "unknown"]
        },
        "quality": {
          "type": "string",
          "enum": ["supportive", "stable", "unstable", "painful", "conflict_prone", "unknown"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "broad_window_days": {
          "type": "integer",
          "minimum": 0
        },
        "exact_window_days": {
          "type": "integer",
          "minimum": 0
        },
        "confidence_decay_days": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dasha_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "transit_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fast_trigger_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "classical_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbolic_label"],
      "properties": {
        "symbolic_label": {
          "type": "string"
        },
        "likelihood_band": {
          "type": "string",
          "enum": ["very_low", "low", "moderate", "high", "very_high"]
        },
        "timing_band": {
          "type": "string",
          "enum": ["broad", "medium", "narrow", "exact", "none"]
        },
        "recommended_action": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operator", "value"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "dasha_lord", "antardasha_lord", "house_lord",
            "planet_in_house", "planet_aspect", "transit_house",
            "transit_aspect", "transit_conjunct", "transit_trine",
            "transit_opposition", "navamsa_house", "navamsa_lagna",
            "navamsa_position", "darakaraka", "mathematical_point",
            "nakshatra", "nakshatra_lord", "age_pattern",
            "sensitive_point", "dignity_status", "sign_type",
            "planetary_significator", "gender", "conjunction", "dispositor"
          ]
        },
        "operator": {
          "type": "string",
          "enum": [
            "equals", "in", "not_in", "overlaps",
            "within_orb", "aspecting", "conjunct",
            "trine", "square", "opposite",
            "is_active", "is_weak", "is_strong",
            "placed_in", "rules", "disposits"
          ]
        },
        "value": {},
        "orb_degrees": {
          "type": "number",
          "minimum": 0
        },
        "required_strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
