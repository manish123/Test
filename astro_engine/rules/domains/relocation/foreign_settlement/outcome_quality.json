      "signals": [
        {
          "signal": "double_moveable_emphasis",
          "weight": 0.6
        },
        {
          "signal": "fortune_abroad_indicator",
          "weight": 0.4
        }
      ],
      "interpretation": {
        "summary": "Double moveable emphasis produces prosperity and financial fortune in foreign lands.",
        "detail": "The native prospers materially through foreign connections, international business, or relocation. The moveable quality ensures adaptability and ability to seize opportunities in new environments.",
        "quality_factors": ["prosperity", "adaptability", "financial_success", "opportunity"]
      },
      "window": null,
      "weights": {
        "base_weight": 0.80,
        "confidence": 0.78,
        "classical_authority": 0.9
      },
      "outputs": {
        "outcome_quality": "prosperous_foreign",
        "settlement_stability": "moderate_to_high",
        "material_comfort": "excellent",
        "emotional_satisfaction": "moderate"
      },
      "metadata": {
        "author": "Vaidyanatha Dikshita",
        "text": "Jataka Parijata",
        "chapter": 15,
        "verse": 26,
        "tradition": "Jyotish",
        "tags": ["prosperity", "fortune", "moveable", "foreign", "quality"]
      }
    },
    {
