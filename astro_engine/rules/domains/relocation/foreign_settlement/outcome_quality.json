    {
      "rule_id": "jp_foreign_death_temple",
      "name": "Permanent Settlement/Isolation Abroad Quality",
      "description": "The combination of Saturn 1st, Mars 12th, and Sun/Moon/Mercury 5th produces permanent settlement with isolation abroad, ultimately ending in death in foreign land.",
      "source_text": "Jataka Parijata v109",
      "domain": "relocation",
      "event_family": "foreign_settlement",
      "event_subtype": "permanent_isolation_quality",
      "rule_type": "outcome_quality",
      "status": "active",
      "priority": 7,
      "polarity": "malefic",
      "timing_band": "none",
      "conditions": {
        "required": [
          {
            "factor": "planet_in_house",
            "planet": "Saturn",
            "house": 1,
            "description": "Saturn must be in the 1st house"
          },
          {
            "factor": "planet_in_house",
            "planet": "Mars",
            "house": 12,
            "description": "Mars must be in the 12th house"
          },
          {
            "factor": "planets_in_house",
            "planets": ["Sun", "Moon", "Mercury"],
            "house": 5,
            "condition": "any_or_all",
            "description": "Sun, Moon, and/or Mercury in the 5th house"
          }
        ],
        "optional": []
      },
      "signals": [
        {
          "signal": "permanent_foreign_isolation",
          "weight": 0.5
        },
        {
          "signal": "saturn_mars_separation",
          "weight": 0.3
        },
        {
          "signal": "5th_house_disconnect",
          "weight": 0.2
        }
      ],
      "interpretation": {
        "summary": "This pattern produces permanent settlement abroad characterized by isolation, ending in death far from homeland.",
        "detail": "The quality of this foreign settlement is one of finality and isolation. Saturn restricts return, Mars drives the native away, and the luminaries in the 5th disconnect from progeny and cultural roots. The settlement is permanent but lonely.",
        "quality_factors": ["isolation", "permanence", "finality", "disconnection"]
      },
      "window": null,
      "weights": {
        "base_weight": 0.75,
        "confidence": 0.65,
        "classical_authority": 0.88
      },
      "outputs": {
        "outcome_quality": "permanent_isolated",
        "settlement_stability": "permanent_but_isolated",
        "material_comfort": "variable",
        "emotional_satisfaction": "low"
      },
      "metadata": {
        "author": "Vaidyanatha Dikshita",
        "text": "Jataka Parijata",
        "verse": 109,
        "tradition": "Jyotish",
        "tags": ["permanent", "isolation", "foreign_death", "saturn", "mars", "quality"]
      }
