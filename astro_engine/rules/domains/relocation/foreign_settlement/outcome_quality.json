{
  "domain": "relocation",
  "event_family": "foreign_settlement",
  "file_type": "outcome_quality",
  "version": "1.0.0",
  "rules": [
    {
      "rule_id": "jp_12th_lord_permanent_foreign",
      "name": "Permanent Settlement Quality - Venus Aspect",
      "description": "The quality of permanent foreign settlement is comfortable and stable when the 12th lord is weak but aspected by Venus, indicating a settled and pleasant life abroad.",
      "source_text": "Jataka Parijata 15:23",
      "domain": "relocation",
      "event_family": "foreign_settlement",
      "event_subtype": "permanent_settlement_quality",
      "rule_type": "outcome_quality",
      "status": "active",
      "priority": 1,
      "polarity": "benefic",
      "timing_band": "none",
      "conditions": {
        "required": [
          {
            "factor": "lord_of_house",
            "house": 12,
            "condition": "weak",
            "description": "12th lord must be weak (debilitated, combust, or in enemy sign)"
          },
          {
            "factor": "aspect",
            "from_planet": "Venus",
            "to_factor": "lord_of_12th",
            "description": "Venus must aspect the 12th lord"
          }
        ],
        "optional": []
      },
      "signals": [
        {
          "signal": "venus_aspect_quality",
          "weight": 0.6
        },
        {
          "signal": "permanent_settlement_indicator",
          "weight": 0.4
        }
      ],
      "interpretation": {
        "summary": "Venus's aspect on the weak 12th lord ensures the permanent foreign settlement is comfortable, aesthetically pleasant, and materially secure.",
        "detail": "The Venus aspect transforms what could be a difficult displacement into a comfortable and attractive foreign life. The native enjoys beauty, luxury, and social pleasantness in their adopted homeland.",
        "quality_factors": ["comfort", "beauty", "social_harmony", "material_security"]
      },
      "window": null,
      "weights": {
        "base_weight": 0.85,
        "confidence": 0.76,
        "classical_authority": 0.9
      },
      "outputs": {
        "outcome_quality": "comfortable_permanent",
        "settlement_stability": "high",
        "material_comfort": "good",
        "emotional_satisfaction": "moderate_to_high"
      },
      "metadata": {
        "author": "Vaidyanatha Dikshita",
        "text": "Jataka Parijata",
        "chapter": 15,
        "verse": 23,
        "tradition": "Jyotish",
        "tags": ["permanent_settlement", "venus", "comfort", "quality"]
      }
    },
    {
      "rule_id": "jp_12th_lord_beautiful_sojourn",
      "name": "Luxurious Temporary Sojourn Quality",
      "description": "The quality of the foreign experience is luxurious and temporary when the 12th lord is strong with benefic aspects, indicating sojourns in beautiful and prosperous foreign lands.",
      "source_text": "Jataka Parijata 15:24",
      "domain": "relocation",
      "event_family": "foreign_settlement",
      "event_subtype": "luxurious_sojourn_quality",
      "rule_type": "outcome_quality",
      "status": "active",
      "priority": 2,
      "polarity": "benefic",
      "timing_band": "none",
      "conditions": {
        "required": [
          {
            "factor": "lord_of_house",
            "house": 12,
            "condition": "strong",
            "description": "12th lord must be strong (exalted, own sign, or friendly sign)"
          },
          {
            "factor": "benefic_aspects",
            "to_factor": "lord_of_12th",
            "description": "Benefic planets must aspect the 12th lord"
          }
        ],
        "optional": []
      },
      "signals": [
        {
          "signal": "12th_lord_dignity",
          "weight": 0.5
        },
        {
          "signal": "benefic_aspect_quality",
          "weight": 0.5
        }
      ],
      "interpretation": {
        "summary": "A strong 12th lord with benefic aspects produces luxurious and aesthetically beautiful foreign sojourns.",
        "detail": "The native experiences foreign lands as places of beauty, luxury, and pleasure. These are temporary but highly enjoyable stays in prosperous and aesthetically pleasing locations.",
        "quality_factors": ["luxury", "beauty", "pleasure", "cultural_richness"]
      },
      "window": null,
      "weights": {
        "base_weight": 0.83,
        "confidence": 0.77,
        "classical_authority": 0.9
      },
      "outputs": {
        "outcome_quality": "luxurious_temporary",
        "settlement_stability": "temporary",
        "material_comfort": "excellent",
        "emotional_satisfaction": "high"
      },
      "metadata": {
        "author": "Vaidyanatha Dikshita",
        "text": "Jataka Parijata",
        "chapter": 15,
        "verse": 24,
        "tradition": "Jyotish",
        "tags": ["luxury", "sojourn", "beautiful_lands", "temporary", "quality"]
      }
    },
    {
      "rule_id": "bphs_12th_house_wandering",
      "name": "Repeated/Unstable Relocation Quality",
      "description": "The quality of foreign settlement is unstable and repetitive when the 12th house is afflicted, causing the native to wander country to country without finding permanent settlement.",
      "source_text": "BPHS 12:11",
      "domain": "relocation",
      "event_family": "foreign_settlement",
      "event_subtype": "unstable_relocation_quality",
      "rule_type": "outcome_quality",
      "status": "active",
      "priority": 3,
      "polarity": "malefic",
      "timing_band": "none",
      "conditions": {
        "required": [
          {
            "factor": "house_affliction",
            "house": 12,
            "condition": "afflicted_by_malefics",
            "description": "12th house must be afflicted by malefic planets"
          }
        ],
        "optional": [
          {
            "factor": "12th_lord_condition",
            "condition": "weak_or_afflicted",
            "description": "Weak or afflicted 12th lord intensifies instability"
          }
        ]
      },
      "signals": [
        {
          "signal": "12th_house_affliction_severity",
          "weight": 0.7
        },
        {
          "signal": "repeated_relocation_pattern",
          "weight": 0.3
        }
      ],
      "interpretation": {
        "summary": "Affliction to the 12th house produces a pattern of repeated, unstable relocations with no permanent foreign home.",
        "detail": "The native experiences foreign settlement as a series of forced moves, never finding stability. Each relocation brings temporary hope followed by displacement, creating a cycle of wandering.",
        "quality_factors": ["instability", "repetition", "displacement", "restlessness"]
      },
      "window": null,
      "weights": {
        "base_weight": 0.82,
        "confidence": 0.80,
        "classical_authority": 0.95
      },
      "outputs": {
        "outcome_quality": "unstable_repeated",
        "settlement_stability": "very_low",
        "material_comfort": "variable",
        "emotional_satisfaction": "low"
      },
      "metadata": {
        "author": "Maharishi Parashara",
        "text": "Brihat Parashara Hora Shastra",
        "chapter": 12,
        "verse": 11,
        "tradition": "Jyotish",
        "tags": ["unstable", "wandering", "repeated", "affliction", "quality"]
      }
    },
    {
      "rule_id": "jp_moveable_lagna_foreign_fortune",
      "name": "Foreign Prosperity Quality",
      "description": "The quality of foreign experience is prosperous and fortunate when moveable Lagna combines with its lord in a moveable sign, indicating material success abroad.",
