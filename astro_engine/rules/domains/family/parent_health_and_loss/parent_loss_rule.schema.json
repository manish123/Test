{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astrolyn.ai/schemas/parent_loss_rule.schema.json",
  "title": "ParentLossRule",
  "description": "Schema for parent health and loss timing and quality rules. Supports the 5-layer semantic architecture: Dasha > Transit > Fast Trigger > Classical Pattern > Outcome/Quality.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "name",
    "domain",
    "event_family",
    "rule_type",
    "status",
    "priority",
    "conditions",
    "outputs"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique rule identifier, e.g. bphs_dasha_ketu_saturn_death_of_parents"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source_text": {
      "type": "object",
      "additionalProperties": false,
      "description": "Provenance tracking - which classical text this rule derives from",
      "properties": {
        "work_name": { "type": "string" },
        "chapter": { "type": ["string", "null"] },
        "verse": { "type": ["string", "null"] },
        "page": { "type": ["string", "null"] },
        "quote": { "type": ["string", "null"] },
        "translation": { "type": ["string", "null"] }
      }
    },
    "domain": {
      "type": "string",
      "enum": ["family", "parents"],
      "description": "Parent loss rules belong to the family domain (parents also acceptable)"
    },
    "event_family": {
      "type": "string",
      "enum": ["parent_health_and_loss"],
      "description": "Event family within the family domain"
    },
    "event_subtype": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "father_death", "mother_death", "parental_loss",
          "father_health_crisis", "mother_health_crisis",
          "father_distress", "mother_distress",
          "parental_separation", "emotional_distance",
          "father_early_death", "mother_early_death",
          "sequential_loss", "father_severe_affliction",
          "parental_abandonment", "orphan_experience",
          "mother_abandonment", "karmic_pattern",
          "inherited_suffering", "father_lineage_curse",
          "generational_curse", "father_accident",
          "sudden_crisis", "father_surgery",
          "mother_surgery", "maternal_emergency",
          "father_chronic_illness", "parental_suffering",
          "unstable_relationship", "parental_conflict",
          "maternal_detachment", "sudden_family_destruction",
          "both_parents_loss", "orphan",
          "father_event", "mother_event"
        ]
      },
      "description": "Qualitative subtypes this rule applies to"
    },
    "rule_type": {
      "type": "string",
      "enum": [
        "dasha",
        "transit",
        "fast_trigger",
        "classical_pattern",
        "combination",
        "house_activation",
        "aspect",
        "compound",
        "d9"
      ],
      "description": "Semantic layer this rule belongs to"
    },
    "status": {
      "type": "string",
      "enum": ["active", "experimental", "calibration", "deprecated"]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Higher value means stronger precedence within its layer"
    },
    "polarity": {
      "type": "string",
      "enum": ["supportive", "neutral", "challenging", "mixed"]
    },
    "timing_band": {
      "type": "string",
      "enum": ["broad", "medium", "narrow", "exact", "none"],
      "description": "How precise this rule's timing is. 'none' = structural/quality rule"
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "all_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          }
        },
        "any_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          }
        },
        "none_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          }
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "description": "What data axes the rule engine must extract to evaluate this rule",
      "properties": {
        "dasha": { "type": "array", "items": { "type": "string" } },
        "transit": { "type": "array", "items": { "type": "string" } },
        "houses": { "type": "array", "items": { "type": "string" } },
        "planets": { "type": "array", "items": { "type": "string" } },
        "nakshatra": { "type": "array", "items": { "type": "string" } },
        "d9": { "type": "array", "items": { "type": "string" } },
        "sensitive_points": { "type": "array", "items": { "type": "string" } }
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "meaning": { "type": "string" },
        "mode": { "type": "string" },
        "quality": { "type": "string", "enum": ["supportive", "challenging", "mixed", "unknown"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "window": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "broad_window_days": { "type": "integer", "minimum": 0 },
        "exact_window_days": { "type": "integer", "minimum": 0 },
        "confidence_decay_days": { "type": "integer", "minimum": 0 }
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dasha_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "transit_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "fast_trigger_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "classical_weight": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbolic_label"],
      "properties": {
        "symbolic_label": { "type": "string" },
        "likelihood_band": { "type": "string", "enum": ["very_low", "low", "moderate", "high", "very_high"] },
        "timing_band": { "type": "string", "enum": ["broad", "medium", "narrow", "exact", "none"] },
        "recommended_action": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operator", "value"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "dasha_lord", "antardasha_lord", "house_lord",
            "planet_in_house", "planet_aspect", "transit_house",
            "transit_aspect", "transit_conjunct", "transit_trine",
            "transit_opposition", "navamsa_house", "navamsa_lagna",
            "navamsa_position", "mathematical_point",
            "nakshatra", "nakshatra_lord", "age_pattern",
            "sensitive_point", "dignity_status", "sign_type",
            "planetary_significator", "conjunction",
            "dispositor", "combustion", "planetary_war",
            "ashtakavarga_bindu", "gandanta", "papa_kartari",
            "maraka_lord", "karaka"
          ]
        },
        "operator": {
          "type": "string",
          "enum": [
            "equals", "in", "not_in", "overlaps",
            "within_orb", "aspecting", "conjunct",
            "trine", "square", "opposite",
            "is_active", "is_weak", "is_strong",
            "placed_in", "rules", "disposits",
            "less_than", "greater_than"
          ]
        },
        "value": {},
        "orb_degrees": { "type": "number", "minimum": 0 },
        "required_strength": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
