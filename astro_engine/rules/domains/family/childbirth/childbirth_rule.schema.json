{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astrolyn.ai/schemas/childbirth_rule.schema.json",
  "title": "ChildbirthRule",
  "description": "Schema for childbirth timing and quality rules. Supports the 5-layer semantic architecture: Dasha > Transit > Fast Trigger > Classical Pattern > Outcome/Quality.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_id",
    "name",
    "domain",
    "event_family",
    "rule_type",
    "status",
    "priority",
    "conditions",
    "outputs"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique rule identifier, e.g. phaladeepika_dasha_primary_childbirth_triggers"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source_text": {
      "type": "object",
      "additionalProperties": false,
      "description": "Provenance tracking — which classical text this rule derives from",
      "properties": {
        "work_name": { "type": "string" },
        "chapter": { "type": ["string", "null"] },
        "verse": { "type": ["string", "null"] },
        "page": { "type": ["string", "null"] },
        "quote": { "type": ["string", "null"] },
        "translation": { "type": ["string", "null"] }
      }
    },
    "domain": {
      "type": "string",
      "enum": ["family"],
      "description": "Childbirth rules belong to the family domain"
    },
    "event_family": {
      "type": "string",
      "enum": ["childbirth", "conception", "pregnancy", "fertility"],
      "description": "Event family within the family domain"
    },
    "event_subtype": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "normal", "delayed", "denied", "multiple",
          "difficult_conception", "difficult_pregnancy",
          "miscarriage_risk", "adoption",
          "child_related_suffering", "conflict_prone",
          "karmic_child_patterns", "multiple_children",
          "delayed_conception"
        ]
      },
      "description": "Qualitative subtypes this rule applies to"
    },
    "rule_type": {
      "type": "string",
      "enum": [
        "dasha",
        "transit",
        "fast_trigger",
        "classical_pattern",
        "combination",
        "house_activation",
        "aspect",
        "compound",
        "d9"
      ],
      "description": "Semantic layer this rule belongs to"
    },
    "status": {
      "type": "string",
      "enum": ["active", "experimental", "calibration", "deprecated"]
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Higher value means stronger precedence within its layer"
    },
    "polarity": {
      "type": "string",
      "enum": ["supportive", "neutral", "challenging", "mixed"]
    },
    "timing_band": {
      "type": "string",
      "enum": ["broad", "medium", "narrow", "exact", "none"],
      "description": "How precise this rule's timing is. 'none' = structural/quality rule"
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "all_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          }
        },
        "any_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          }
        },
        "none_of": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/Condition" },
              { "type": "string" }
            ]
          }
        }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "description": "What data axes the rule engine must extract to evaluate this rule",
      "properties": {
        "dasha": { "type": "array", "items": { "type": "string" } },
        "transit": { "type": "array", "items": { "type": "string" } },
        "houses": { "type": "array", "items": { "type": "string" } },
        "planets": { "type": "array", "items": { "type": "string" } },
        "nakshatra": { "type": "array", "items": { "type": "string" } },
        "d9": { "type": "array", "items": { "type": "string" } },
        "sensitive_points": { "type": "array", "items": { "type": "string" } }
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "meaning": { "type": "string" },
        "mode": { "type": "string", "enum": ["natural", "ivf", "surrogacy", "adoption", "unknown"] },
        "quality": { "type": "string", "enum": ["supportive", "difficult", "painful", "delayed", "unknown"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "broad_window_days": { "type": "integer", "minimum": 0 },
        "exact_window_days": { "type": "integer", "minimum": 0 },
        "confidence_decay_days": { "type": "integer", "minimum": 0 }
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dasha_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "transit_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "fast_trigger_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "classical_weight": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbolic_label"],
      "properties": {
        "symbolic_label": { "type": "string" },
        "likelihood_band": { "type": "string", "enum": ["very_low", "low", "moderate", "high", "very_high"] },
        "timing_band": { "type": "string", "enum": ["broad", "medium", "narrow", "exact", "none"] },
        "recommended_action": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operator", "value"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "dasha_lord", "antardasha_lord", "house_lord",
            "planet_in_house", "planet_aspect", "transit_house",
            "transit_aspect", "transit_conjunct", "transit_trine",
            "transit_opposition", "navamsa_house", "navamsa_lagna",
            "navamsa_position", "putrakaraka", "mathematical_point",
            "nakshatra", "nakshatra_lord", "age_pattern",
            "sensitive_point", "dignity_status", "sign_type",
            "planetary_significator", "gender", "conjunction",
            "dispositor", "combustion", "planetary_war"
          ]
        },
        "operator": {
          "type": "string",
          "enum": [
            "equals", "in", "not_in", "overlaps",
            "within_orb", "aspecting", "conjunct",
            "trine", "square", "opposite",
            "is_active", "is_weak", "is_strong",
            "placed_in", "rules", "disposits"
          ]
        },
        "value": {},
        "orb_degrees": { "type": "number", "minimum": 0 },
        "required_strength": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
