{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astrolyn.ai/schemas/property_rule.schema.json",
  "title": "PropertyRule",
  "description": "Schema for ancestral property & inheritance domain event rules. Covers all 5 semantic layers: dasha, transit, fast_trigger, classical_pattern, and outcome/quality classification.",
  "type": "object",
  "additionalProperties": false,
  "required": ["rule_id", "name", "domain", "event_family", "rule_type", "status", "priority", "conditions", "outputs"],
  "properties": {
    "rule_id": {"type": "string", "minLength": 1, "description": "Unique rule identifier, e.g. fourth_lord_property_dasha"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "source_text": {
      "type": "object",
      "additionalProperties": true,
      "description": "Classical source provenance for audit and scholarly validation",
      "properties": {
        "work_name": {"type": "string"},
        "chapter": {"type": ["string", "null"]},
        "verse": {"type": ["string", "null"]},
        "page": {"type": ["string", "null"]},
        "quote": {"type": ["string", "null"]},
        "translation": {"type": ["string", "null"]}
      }
    },
    "domain": {"type": "string", "enum": ["finance"], "description": "Property rules belong to the finance domain"},
    "event_family": {
      "type": "string",
      "enum": ["ancestral_property_and_inheritance"],
      "description": "Type of finance event"
    },
    "event_subtype": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Specific sub-events: property_acquisition, inheritance, land_purchase, disputes, paternal_property, etc."
    },
    "rule_type": {
      "type": "string",
      "enum": ["dasha", "transit", "fast_trigger", "classical_pattern", "compound", "combination", "yoga", "house_activation", "d9", "aspect"]
    },
    "status": {"type": "string", "enum": ["active", "experimental", "calibration", "deprecated"]},
    "priority": {"type": "integer", "minimum": 1, "maximum": 100, "description": "Higher value means stronger precedence within its layer"},
    "polarity": {"type": "string", "enum": ["supportive", "neutral", "challenging", "mixed"]},
    "timing_band": {
      "type": "string",
      "enum": ["broad", "medium", "narrow", "exact", "none"],
      "description": "broad=dasha-level, medium=transit-level, narrow=refined, exact=fast-trigger-level, none=natal/structural"
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all_of"],
      "properties": {
        "all_of": {"type": "array", "description": "ALL of these must be true"},
        "any_of": {"type": "array", "description": "At least ONE of these must be true"},
        "none_of": {"type": "array", "description": "NONE of these may be true"}
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "description": "Declares what data the engine must extract to evaluate this rule",
      "properties": {
        "dasha": {"type": "array", "items": {"type": "string"}},
        "transit": {"type": "array", "items": {"type": "string"}},
        "houses": {"type": "array", "items": {"type": "string"}},
        "planets": {"type": "array", "items": {"type": "string"}},
        "nakshatra": {"type": "array", "items": {"type": "string"}},
        "d9": {"type": "array", "items": {"type": "string"}},
        "sensitive_points": {"type": "array", "items": {"type": "string"}}
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": true,
      "description": "Human-readable interpretation metadata",
      "properties": {
        "meaning": {"type": "string"},
        "mode": {"type": "string", "description": "Property mode: smooth_inheritance, disputed_property, sudden_gain, karmic_pattern, inherited_debt"},
        "quality": {"type": "string", "description": "Quality: supportive, challenging, mixed"},
        "asset_type": {"type": "string", "description": "Asset type: land, liquid_wealth, luxury_assets, inaccessible"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1, "description": "Source-level confidence (0-1)"}
      }
    },
    "window": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "description": "Timing window parameters. Null for structural/quality rules (timing_band=none)",
      "properties": {
        "broad_window_days": {"type": "integer", "minimum": 0},
        "exact_window_days": {"type": "integer", "minimum": 0},
        "confidence_decay_days": {"type": "integer", "minimum": 0}
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dasha_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "transit_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "fast_trigger_weight": {"type": "number", "minimum": 0, "maximum": 1},
        "classical_weight": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbolic_label", "likelihood_band", "timing_band"],
      "properties": {
        "symbolic_label": {"type": "string", "description": "Neutral interpretation label, e.g. property_window_active"},
        "likelihood_band": {"type": "string", "enum": ["very_low", "low", "moderate", "high", "very_high"]},
        "timing_band": {"type": "string", "enum": ["broad", "narrow", "exact", "none"]},
        "recommended_action": {"type": "string", "description": "Domain-facing guidance: pursue_property, protect_assets, engage_lawyer, etc."}
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional provenance, calibration, and implementation notes",
      "properties": {
        "notes": {"type": "string"}
      }
    }
  }
}
